# ========================================
# AI 爆款文章创作器 - 环境变量配置（Go 版本）
# ========================================
# 复制此文件为 .env 并填写配置
# cp .env.example .env

# ============ 必需配置 ============

# 阿里云 DashScope API Key（必需）
# 获取地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key

# Pexels 图片 API Key（必需）
# 获取地址：https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key

# ============ 数据库配置 ============

MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=ai_passage_creator

# Redis 密码（默认设置，无需修改）
REDIS_PASSWORD=redis123

# ============ 服务配置 ============

TZ=Asia/Shanghai
BACKEND_PORT=8123
FRONTEND_PORT=80

# ============ 可选配置 ============

# Nano Banana (Gemini) API Key（AI 生图，VIP 功能）
# NANO_BANANA_API_KEY=

# Stripe 支付配置（VIP 功能）
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# 腾讯云 COS 配置（图片存储）
# TENCENT_COS_SECRET_ID=
# TENCENT_COS_SECRET_KEY=
# TENCENT_COS_REGION=ap-beijing
# TENCENT_COS_BUCKET=

