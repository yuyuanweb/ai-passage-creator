# 配置文件示例
# 使用说明：将此文件复制为 config.yaml，并填写实际的配置值
# 注意：config.yaml 已在 .gitignore 中，不会被提交到 Git

server:
  port: 8567
  context_path: /api

database:
  host: localhost
  port: 3306
  name: ai_passage_creator
  user: root
  password: "your-password"  # 请填写实际密码
  max_idle_conns: 10
  max_open_conns: 100

redis:
  host: localhost
  port: 6379
  db: 0
  password: ""  # Redis 密码，如无则留空

session:
  secret: "your-session-secret-change-this"  # 请生成随机密钥
  max_age: 2592000  # 30天（秒）

# 阿里云 DashScope 配置
ai:
  dashscope:
    api_key: "your-dashscope-api-key"  # https://bailian.console.aliyun.com/
    model: "qwen-max"

# Pexels 图片 API 配置
pexels:
  api_key: "your-pexels-api-key"  # https://www.pexels.com/api/

# Iconify 图标库配置
iconify:
  base_url: "https://api.iconify.design"
  timeout: 5000  # 毫秒

# Mermaid 流程图配置
mermaid:
  cli: "mmdc"  # 需要全局安装 @mermaid-js/mermaid-cli: npm install -g @mermaid-js/mermaid-cli
  output_format: "png"  # png/svg/pdf
  theme: "default"  # default/dark/forest
  width: 1200
  height: 800
  timeout: 30000  # 毫秒

# Nano Banana (Gemini) AI 生图配置
nano_banana:
  api_key: "your-gemini-api-key"  # Google AI Studio: https://aistudio.google.com/apikey
  model: "gemini-2.5-flash-image"
  aspect_ratio: "16:9"  # 16:9/1:1/9:16
  image_size: "1024x1024"

# SVG 概念示意图配置
svg_diagram:
  enabled: true

# 表情包检索配置
emoji_pack:
  suffix: "表情包"
  timeout: 10000  # 毫秒

# 腾讯云 COS 配置
cos:
  secret_id: "your-cos-secret-id"
  secret_key: "your-cos-secret-key"
  region: "ap-beijing"  # 地域，如：ap-beijing, ap-shanghai, ap-guangzhou
  bucket: "your-bucket-name"
  domain: ""  # CDN 加速域名（可选），如：https://cdn.example.com

log:
  level: info  # debug, info, warn, error
  file_path: logs/app.log
