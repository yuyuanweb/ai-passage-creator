# 服务器配置
SERVER_PORT=8567
SERVER_HOST=0.0.0.0

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_passage_creator
DB_USER=root
DB_PASSWORD=123456

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Session 配置
SESSION_SECRET_KEY=your-secret-key-change-in-production
SESSION_MAX_AGE=2592000

# 密码加密盐值
PASSWORD_SALT=yupi

# AI 配置（第 3 期新增）
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_MODEL=qwen-plus

# Pexels 图片搜索（第 3 期新增）
PEXELS_API_KEY=your-pexels-api-key

# 腾讯云 COS（第 3 期新增）
TENCENT_COS_SECRET_ID=your-cos-secret-id
TENCENT_COS_SECRET_KEY=your-cos-secret-key
TENCENT_COS_REGION=ap-beijing
TENCENT_COS_BUCKET=your-bucket-name
TENCENT_COS_DOMAIN=

# Nano Banana / Gemini AI 生图（第 5 期新增）
NANO_BANANA_API_KEY=your-gemini-api-key
NANO_BANANA_MODEL=gemini-2.5-flash-image
NANO_BANANA_ASPECT_RATIO=16:9
NANO_BANANA_IMAGE_SIZE=1K
NANO_BANANA_OUTPUT_MIME_TYPE=image/png

# Mermaid 配置（第 5 期新增）
MERMAID_CLI_COMMAND=mmdc
MERMAID_BACKGROUND_COLOR=transparent
MERMAID_OUTPUT_FORMAT=svg
MERMAID_WIDTH=1200
MERMAID_TIMEOUT=30000

# Iconify 配置（第 5 期新增）
ICONIFY_API_URL=https://api.iconify.design
ICONIFY_SEARCH_LIMIT=10
ICONIFY_DEFAULT_HEIGHT=64
ICONIFY_DEFAULT_COLOR=

# 表情包配置（第 5 期新增）
EMOJI_PACK_SEARCH_URL=https://cn.bing.com/images/async
EMOJI_PACK_SUFFIX=表情包
EMOJI_PACK_TIMEOUT=10000

# SVG 示意图配置（第 5 期新增）
SVG_DIAGRAM_DEFAULT_WIDTH=800
SVG_DIAGRAM_DEFAULT_HEIGHT=600
SVG_DIAGRAM_FOLDER=svg-diagrams
